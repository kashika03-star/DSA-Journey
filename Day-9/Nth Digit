class Solution {
public:
    int findNthDigit(int n) {

        long long digitLength = 1;
        long long count = 9;
        long long start = 1;

        while (n > digitLength * count) {
            n -= digitLength * count;
            digitLength++;
            count *= 10;
            start *= 10;
        }

        start += (n - 1) / digitLength;

        string num = to_string(start);

        return num[(n - 1) % digitLength] - '0';
    }
};
